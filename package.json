{
  "name": "vanilla-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:empty": "vitest run --coverage --passWithNoTests nonexistent",
    "lint": "eslint src/",
    "lint:report": "eslint src/ --format html --output-file eslint-report.html"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-istanbul": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.0.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "history": "^5.3.0"
  }
}
